<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity"
            minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="614.0" prefWidth="942.0"
            xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.smarthotel.gui.controllers.TelaBuscarHospedagemController">

   <children>

      <Label layoutX="374.0" layoutY="49.0" text="SMART HOTEL">
         <font>
            <Font name="System Bold" size="28.0" />
         </font>
      </Label>

      <Label layoutX="403.0" layoutY="109.0" text="Buscar Hospedagem">
         <font>
            <Font name="System Bold" size="14.0" />
         </font>
      </Label>

      <Label layoutX="32.0" layoutY="202.0" text="Insira o ID da Hospedagem:">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Label>

      <TextField fx:id="txtIdHospedagem"
                 layoutX="201.0"
                 layoutY="198.0"
                 prefHeight="26.0"
                 prefWidth="90.0" />

      <Button fx:id="btnBuscar"
              layoutX="307.0"
              layoutY="198.0"
              mnemonicParsing="false"
              onAction="#buscarHospedagem"
              text="Buscar">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Button>

      <Label layoutX="38.0" layoutY="251.0" text="Hospedagens Ativas:">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Label>

      <ListView fx:id="listHospedes"
                layoutX="38.0"
                layoutY="283.0"
                prefHeight="236.0"
                prefWidth="210.0" />

      <Label layoutX="690.0" layoutY="251.0" text="Hospedagens Reservadas:">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Label>

      <ListView layoutX="690.0"
                layoutY="282.0"
                prefHeight="236.0"
                prefWidth="210.0" />

      <Button fx:id="btnVoltar"
              layoutX="444.0"
              layoutY="505.0"
              mnemonicParsing="false"
              onAction="#voltar"
              prefHeight="26.0"
              prefWidth="60.0"
              text="Voltar">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Button>


      <Label fx:id="lblResponsavel" visible="false" text="-" />
      <Label fx:id="lblQuarto" visible="false" text="-" />
      <Label fx:id="lblStatus" visible="false" text="-" />
      <Label fx:id="lblEntrada" visible="false" text="-" />
      <Label fx:id="lblSaida" visible="false" text="-" />

   </children>
</AnchorPane>