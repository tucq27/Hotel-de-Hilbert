<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity"
            minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="400.0" prefWidth="600.0"
            xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.smarthotel.gui.controllers.TelaAdministrarHospedagensController">

   <children>

      <Label layoutX="203.0" layoutY="51.0" text="SMART HOTEL">
         <font>
            <Font name="System Bold" size="28.0" />
         </font>
      </Label>

      <Label layoutX="214.0" layoutY="99.0" text="Administrar Hospedagens">
         <font>
            <Font name="System Bold" size="14.0" />
         </font>
      </Label>

      <Button fx:id="btnHospedagemAgora"
              layoutX="211.0"
              layoutY="174.0"
              mnemonicParsing="false"
              onAction="#abrirHospedagemAgora"
              prefHeight="30.0"
              prefWidth="186.0"
              text="Realizar Hospedagem Agora">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Button>

      <Button fx:id="btnHospedagemPrevia"
              layoutX="210.0"
              layoutY="218.0"
              mnemonicParsing="false"
              onAction="#abrirHospedagemPrevia"
              prefHeight="30.0"
              prefWidth="186.0"
              text="Realizar Hospedagem Prévia">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Button>

      <Button fx:id="btnBuscarHospedagem"
              layoutX="210.0"
              layoutY="264.0"
              mnemonicParsing="false"
              onAction="#abrirBuscarHospedagem"
              prefHeight="30.0"
              prefWidth="186.0"
              text="Buscar Hospedagem">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Button>

      <Button fx:id="btnVoltar"
              layoutX="274.0"
              layoutY="345.0"
              mnemonicParsing="false"
              onAction="#voltar"
              text="Voltar">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Button>

   </children>
</AnchorPane>