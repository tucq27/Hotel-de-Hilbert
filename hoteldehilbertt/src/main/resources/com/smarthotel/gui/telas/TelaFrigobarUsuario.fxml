<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity"
            minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="500.0" prefWidth="600.0"
            xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.smarthotel.gui.controllers.FrigobarUsuario">

    <children>

        <Label layoutX="210.0" layoutY="55.0" text="SMART HOTEL">
            <font>
                <Font name="System Bold" size="28.0" />
            </font>
        </Label>

        <Label layoutX="250.0" layoutY="95.0" text="Frigobar">
            <font>
                <Font name="System Bold Italic" size="14.0" />
            </font>
        </Label>

        <Label layoutX="70.0" layoutY="140.0" text="Itens no Frigobar:">
            <font>
                <Font name="System Bold" size="13.0" />
            </font>
        </Label>

        <ListView fx:id="listItensFrigobar"
                  layoutX="70.0"
                  layoutY="170.0"
                  prefHeight="180.0"
                  prefWidth="460.0" />

        <Label layoutX="70.0" layoutY="375.0" text="Escolha o item:">
            <font>
                <Font name="System Bold" size="12.0" />
            </font>
        </Label>

        <ComboBox fx:id="cbItensFrigobar"
                  layoutX="170.0"
                  layoutY="370.0"
                  prefHeight="30.0"
                  prefWidth="230.0" />

        <Button fx:id="btnPegarItem"
                layoutX="415.0"
                layoutY="370.0"
                mnemonicParsing="false"
                onAction="#pegarItem"
                prefHeight="30.0"
                prefWidth="115.0"
                text="Pegar Item">
            <font>
                <Font name="System Bold" size="12.0" />
            </font>
        </Button>

        <Button fx:id="btnVoltar"
                layoutX="258.0"
                layoutY="435.0"
                mnemonicParsing="false"
                onAction="#voltar"
                prefHeight="28.0"
                prefWidth="84.0"
                text="Voltar">
            <font>
                <Font name="System Bold" size="12.0" />
            </font>
        </Button>

    </children>
</AnchorPane>