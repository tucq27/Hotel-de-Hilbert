<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="650.0" prefWidth="800.0"
            xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.smarthotel.gui.controllers.TelaGerenciarFuncionarioController">

    <children>

        <Label layoutX="300.0" layoutY="35.0" text="SMART HOTEL">
            <font>
                <Font name="System Bold" size="28.0"/>
            </font>
        </Label>

        <Label layoutX="320.0" layoutY="80.0" text="Gerenciar Funcionário">
            <font>
                <Font name="System Bold" size="14.0"/>
            </font>
        </Label>

        <Label layoutX="80.0" layoutY="130.0" text="Nome:"/>
        <Label fx:id="lblNome" layoutX="220.0" layoutY="130.0" text="-"/>

        <Label layoutX="80.0" layoutY="160.0" text="CPF:"/>
        <Label fx:id="lblCpf" layoutX="220.0" layoutY="160.0" text="-"/>

        <Label layoutX="80.0" layoutY="190.0" text="Nascimento:"/>
        <Label fx:id="lblNascimento" layoutX="220.0" layoutY="190.0" text="-"/>

        <Label layoutX="80.0" layoutY="220.0" text="Telefone:"/>
        <Label fx:id="lblTelefone" layoutX="220.0" layoutY="220.0" text="-"/>

        <Label layoutX="80.0" layoutY="250.0" text="Email:"/>
        <Label fx:id="lblEmail" layoutX="220.0" layoutY="250.0" text="-"/>

        <Label layoutX="80.0" layoutY="280.0" text="Cargo:"/>
        <Label fx:id="lblCargo" layoutX="220.0" layoutY="280.0" text="-"/>

        <Label layoutX="80.0" layoutY="310.0" text="Ocupado:"/>
        <Label fx:id="lblOcupado" layoutX="220.0" layoutY="310.0" text="-"/>

        <Label layoutX="80.0" layoutY="380.0" text="Novo Nome:"/>
        <TextField fx:id="txtNovoNome"
                   layoutX="220.0"
                   layoutY="375.0"
                   prefWidth="220.0"/>

        <Label layoutX="80.0" layoutY="420.0" text="Novo Telefone:"/>
        <TextField fx:id="txtNovoTelefone"
                   layoutX="220.0"
                   layoutY="415.0"
                   prefWidth="220.0"/>

        <Label layoutX="80.0" layoutY="460.0" text="Novo Email:"/>
        <TextField fx:id="txtNovoEmail"
                   layoutX="220.0"
                   layoutY="455.0"
                   prefWidth="220.0"/>

        <Label layoutX="500.0" layoutY="380.0" text="Novo Cargo:"/>
        <TextField fx:id="txtNovoCargo"
                   layoutX="590.0"
                   layoutY="375.0"
                   prefWidth="150.0"/>

        <Label layoutX="500.0" layoutY="430.0" text="Ocupado:"/>
        <ComboBox fx:id="cbOcupado"
                  layoutX="590.0"
                  layoutY="425.0"
                  prefWidth="150.0"/>

        <Button fx:id="btnAtualizar"
                layoutX="240.0"
                layoutY="580.0"
                mnemonicParsing="false"
                onAction="#atualizarFuncionario"
                text="Atualizar"/>

        <Button fx:id="btnExcluir"
                layoutX="360.0"
                layoutY="580.0"
                mnemonicParsing="false"
                onAction="#excluirFuncionario"
                text="Excluir"/>

        <Button fx:id="btnVoltar"
                layoutX="480.0"
                layoutY="580.0"
                mnemonicParsing="false"
                onAction="#voltar"
                text="Voltar"/>

    </children>
</AnchorPane>