<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity"
            minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="400.0" prefWidth="600.0"
            xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.smarthotel.gui.controllers.AdminItens">

   <children>

      <Label layoutX="220.0" layoutY="32.0" text="Smart Hotel">
         <font>
            <Font name="System Bold" size="28.0" />
         </font>
      </Label>

      <Label layoutX="242.0" layoutY="82.0" text="Administrar Itens">
         <font>
            <Font name="System Bold Italic" size="14.0" />
         </font>
      </Label>

      <Button fx:id="btnCadastrarItem"
              layoutX="206.0" layoutY="178.0"
              mnemonicParsing="false"
              onAction="#abrirCadastrarItem"
              prefHeight="30.0" prefWidth="186.0"
              text="Cadastrar Item">
         <font>
            <Font name="System Bold" size="14.0" />
         </font>
      </Button>

      <Button fx:id="btnBuscarItem"
              layoutX="206.0" layoutY="246.0"
              mnemonicParsing="false"
              onAction="#abrirBuscarItem"
              prefHeight="30.0" prefWidth="186.0"
              text="Buscar Item">
         <font>
            <Font name="System Bold" size="14.0" />
         </font>
      </Button>

      <Button fx:id="btnVoltar"
              layoutX="270.0"
              layoutY="350.0"
              mnemonicParsing="false"
              onAction="#voltar"
              text="Voltar">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Button>

   </children>
</AnchorPane>