<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity"
            minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="400.0" prefWidth="600.0"
            xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.smarthotel.gui.controllers.TelaCadastrarItemController">

    <children>

        <Label layoutX="220.0" layoutY="32.0" text="Smart Hotel">
            <font>
                <Font name="System Bold" size="28.0" />
            </font>
        </Label>

        <Label layoutX="245.0" layoutY="82.0" text="Cadastrar Item">
            <font>
                <Font name="System Bold Italic" size="14.0" />
            </font>
        </Label>

        <Label layoutX="170.0" layoutY="155.0" text="Nome:">
            <font>
                <Font name="System Bold" size="12.0" />
            </font>
        </Label>

        <TextField fx:id="txtNome"
                   layoutX="230.0"
                   layoutY="150.0"
                   prefWidth="180.0" />

        <Label layoutX="170.0" layoutY="210.0" text="Valor:">
            <font>
                <Font name="System Bold" size="12.0" />
            </font>
        </Label>

        <TextField fx:id="txtValor"
                   layoutX="230.0"
                   layoutY="205.0"
                   prefWidth="180.0" />

        <Button fx:id="btnCadastrar"
                layoutX="230.0"
                layoutY="275.0"
                mnemonicParsing="false"
                onAction="#cadastrarItem"
                prefHeight="30.0"
                prefWidth="180.0"
                text="Cadastrar">
            <font>
                <Font name="System Bold" size="13.0" />
            </font>
        </Button>

        <Button fx:id="btnVoltar"
                layoutX="270.0"
                layoutY="350.0"
                mnemonicParsing="false"
                onAction="#voltar"
                text="Voltar">
            <font>
                <Font name="System Bold" size="12.0" />
            </font>
        </Button>

    </children>
</AnchorPane>