<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity"
            minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="523.0" prefWidth="766.0"
            xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.smarthotel.gui.controllers.PrincipalUsuario">

    <children>

        <Label layoutX="285.0" layoutY="80.0" text="SMART HOTEL">
            <font>
                <Font name="System Bold" size="28.0" />
            </font>
        </Label>

        <Label layoutX="329.0" layoutY="120.0" text="Área do Usuário">
            <font>
                <Font name="System Bold Italic" size="14.0" />
            </font>
        </Label>

        <Button fx:id="btnRealizarReserva"
                layoutX="287.0"
                layoutY="190.0"
                mnemonicParsing="false"
                onAction="#realizarReserva"
                prefHeight="34.0"
                prefWidth="192.0"
                text="Realizar Reserva">
            <font>
                <Font name="System Bold" size="13.0" />
            </font>
        </Button>

        <Button fx:id="btnBuscarReserva"
                layoutX="287.0"
                layoutY="250.0"
                mnemonicParsing="false"
                onAction="#buscarReserva"
                prefHeight="34.0"
                prefWidth="192.0"
                text="Buscar Reserva">
            <font>
                <Font name="System Bold" size="13.0" />
            </font>
        </Button>

        <Button fx:id="btnVerHospedagemAtual"
                layoutX="287.0"
                layoutY="310.0"
                mnemonicParsing="false"
                onAction="#verHospedagemAtual"
                prefHeight="34.0"
                prefWidth="192.0"
                text="Ver Hospedagem Atual">
            <font>
                <Font name="System Bold" size="13.0" />
            </font>
        </Button>

        <Button fx:id="btnVoltar"
                layoutX="343.0"
                layoutY="390.0"
                mnemonicParsing="false"
                onAction="#voltar"
                prefHeight="26.0"
                prefWidth="84.0"
                text="Voltar">
            <font>
                <Font name="System Bold" size="12.0" />
            </font>
        </Button>

    </children>
</AnchorPane>