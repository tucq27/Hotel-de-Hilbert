<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity"
            minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="523.0" prefWidth="766.0"
            xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.smarthotel.gui.controllers.LoginUsuario">

    <children>

        <Label layoutX="285.0" layoutY="80.0" text="SMART HOTEL">
            <font>
                <Font name="System Bold" size="28.0" />
            </font>
        </Label>

        <Label layoutX="321.0"
               layoutY="120.0"
               text="Área do Usuário">
            <font>
                <Font name="System Bold Italic" size="14.0" />
            </font>
        </Label>

        <Label layoutX="285.0"
               layoutY="210.0"
               text="CPF:">
            <font>
                <Font name="System Bold" size="14.0" />
            </font>
        </Label>

        <TextField fx:id="txtCpf"
                   layoutX="285.0"
                   layoutY="235.0"
                   prefHeight="30.0"
                   prefWidth="200.0"
                   promptText="Digite seu CPF" />

        <Button fx:id="btnEntrar"
                layoutX="292.0"
                layoutY="310.0"
                mnemonicParsing="false"
                onAction="#entrar"
                prefHeight="30.0"
                prefWidth="186.0"
                text="Entrar">
            <font>
                <Font name="System Bold" size="13.0" />
            </font>
        </Button>

        <Button fx:id="btnVoltar"
                layoutX="343.0"
                layoutY="370.0"
                mnemonicParsing="false"
                onAction="#voltar"
                prefHeight="26.0"
                prefWidth="84.0"
                text="Voltar">
            <font>
                <Font name="System Bold" size="12.0" />
            </font>
        </Button>

    </children>

</AnchorPane>