<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity"
            minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="520.0" prefWidth="700.0"
            xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.smarthotel.gui.controllers.GerenciarQuarto">

    <children>

        <Label layoutX="270.0" layoutY="32.0" text="Smart Hotel">
            <font>
                <Font name="System Bold" size="28.0" />
            </font>
        </Label>

        <Label layoutX="285.0" layoutY="82.0" text="Gerenciar Quarto">
            <font>
                <Font name="System Bold Italic" size="14.0" />
            </font>
        </Label>

        <Label layoutX="180.0" layoutY="130.0" text="ID:" />
        <Label fx:id="lblIdQuarto" layoutX="310.0" layoutY="130.0" text="-" />

        <Label layoutX="180.0" layoutY="160.0" text="Número atual:" />
        <Label fx:id="lblNumeroQuarto" layoutX="310.0" layoutY="160.0" text="-" />

        <Label layoutX="180.0" layoutY="190.0" text="Andar atual:" />
        <Label fx:id="lblAndarQuarto" layoutX="310.0" layoutY="190.0" text="-" />

        <Label layoutX="180.0" layoutY="220.0" text="Capacidade atual:" />
        <Label fx:id="lblCapacidadeQuarto" layoutX="310.0" layoutY="220.0" text="-" />

        <Label layoutX="180.0" layoutY="250.0" text="Status:" />
        <Label fx:id="lblStatusQuarto" layoutX="310.0" layoutY="250.0" text="-" />

        <Label layoutX="180.0" layoutY="280.0" text="Tipo atual:" />
        <Label fx:id="lblTipoQuarto" layoutX="310.0" layoutY="280.0" text="-" />

        <Label layoutX="180.0" layoutY="325.0" text="Novo número:" />
        <TextField fx:id="txtNovoNumero" layoutX="310.0" layoutY="320.0" prefWidth="160.0" />

        <Label layoutX="180.0" layoutY="365.0" text="Novo andar:" />
        <TextField fx:id="txtNovoAndar" layoutX="310.0" layoutY="360.0" prefWidth="160.0" />

        <Label layoutX="180.0" layoutY="405.0" text="Nova capacidade:" />
        <TextField fx:id="txtNovaCapacidade" layoutX="310.0" layoutY="400.0" prefWidth="160.0" />

        <Label layoutX="180.0" layoutY="445.0" text="Novo tipo:" />
        <ComboBox fx:id="cbTipoQuarto" layoutX="310.0" layoutY="440.0" prefWidth="160.0" />

        <Button fx:id="btnAtualizar"
                layoutX="500.0" layoutY="320.0"
                mnemonicParsing="false"
                onAction="#atualizarQuarto"
                prefWidth="120.0"
                text="Atualizar" />

        <Button fx:id="btnExcluir"
                layoutX="500.0" layoutY="365.0"
                mnemonicParsing="false"
                onAction="#excluirQuarto"
                prefWidth="120.0"
                text="Excluir" />

        <Button fx:id="btnVoltar"
                layoutX="500.0" layoutY="440.0"
                mnemonicParsing="false"
                onAction="#voltar"
                prefWidth="120.0"
                text="Voltar" />

    </children>
</AnchorPane>