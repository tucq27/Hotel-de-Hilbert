<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity"
            minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="450.0" prefWidth="600.0"
            xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.smarthotel.gui.controllers.AdminPessoas">

   <children>

      <Label layoutX="220.0" layoutY="32.0" text="Smart Hotel">
         <font>
            <Font name="System Bold" size="28.0" />
         </font>
      </Label>

      <Label layoutX="233.0" layoutY="85.0" text="Administrar Pessoas">
         <font>
            <Font name="System Bold Italic" size="14.0" />
         </font>
      </Label>

      <Button fx:id="btnCadastrarHospede"
              layoutX="206.0"
              layoutY="140.0"
              mnemonicParsing="false"
              onAction="#abrirCadastrarHospede"
              prefHeight="30.0"
              prefWidth="186.0"
              text="Cadastrar Hóspede">
         <font>
            <Font name="System Bold" size="14.0" />
         </font>
      </Button>

      <Button fx:id="btnCadastrarFuncionario"
              layoutX="206.0"
              layoutY="190.0"
              mnemonicParsing="false"
              onAction="#abrirCadastrarFuncionario"
              prefHeight="30.0"
              prefWidth="186.0"
              text="Cadastrar Funcionário">
         <font>
            <Font name="System Bold" size="14.0" />
         </font>
      </Button>

      <Button fx:id="btnCadastrarPessoa"
              layoutX="206.0"
              layoutY="240.0"
              mnemonicParsing="false"
              onAction="#abrirCadastrarPessoa"
              prefHeight="30.0"
              prefWidth="186.0"
              text="Cadastrar Pessoa">
         <font>
            <Font name="System Bold" size="14.0" />
         </font>
      </Button>

      <Button fx:id="btnBuscarPessoa"
              layoutX="206.0"
              layoutY="290.0"
              mnemonicParsing="false"
              onAction="#abrirBuscarPessoa"
              prefHeight="30.0"
              prefWidth="186.0"
              text="Buscar Pessoa">
         <font>
            <Font name="System Bold" size="14.0" />
         </font>
      </Button>

      <Button fx:id="btnVoltar"
              layoutX="270.0"
              layoutY="380.0"
              mnemonicParsing="false"
              onAction="#voltar"
              text="Voltar">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Button>

   </children>
</AnchorPane>