<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity"
            minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="600.0" prefWidth="800.0"
            xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.smarthotel.gui.controllers.BuscarPessoa">

    <children>

        <Label layoutX="306.0" layoutY="53.0" text="SMART HOTEL">
            <font>
                <Font name="System Bold" size="28.0" />
            </font>
        </Label>

        <Label layoutX="350.0" layoutY="93.0" text="Buscar Pessoa">
            <font>
                <Font name="System Bold Italic" size="14.0" />
            </font>
        </Label>

        <Label layoutX="66.0" layoutY="153.0" text="Insira o CPF:">
            <font>
                <Font name="System Bold" size="12.0" />
            </font>
        </Label>

        <TextField fx:id="txtCpfPessoa"
                   layoutX="150.0"
                   layoutY="148.0"
                   prefHeight="26.0"
                   prefWidth="170.0" />

        <Button fx:id="btnBuscar"
                layoutX="345.0"
                layoutY="148.0"
                mnemonicParsing="false"
                onAction="#buscarPessoa"
                text="Buscar">
            <font>
                <Font name="System Bold" size="12.0" />
            </font>
        </Button>

        <Label layoutX="85.0" layoutY="208.0" text="Hóspedes Registrados:">
            <font>
                <Font name="System Bold" size="12.0" />
            </font>
        </Label>

        <ListView fx:id="listHospedes"
                  layoutX="33.0"
                  layoutY="239.0"
                  prefHeight="265.0"
                  prefWidth="302.0" />

        <Label layoutX="540.0" layoutY="208.0" text="Funcionários Registrados:">
            <font>
                <Font name="System Bold" size="12.0" />
            </font>
        </Label>

        <ListView fx:id="listFuncionarios"
                  layoutX="468.0"
                  layoutY="239.0"
                  prefHeight="265.0"
                  prefWidth="302.0" />

        <Button fx:id="btnVoltar"
                layoutX="373.0"
                layoutY="504.0"
                mnemonicParsing="false"
                onAction="#voltar"
                prefHeight="26.0"
                prefWidth="60.0"
                text="Voltar">
            <font>
                <Font name="System Bold" size="12.0" />
            </font>
        </Button>

    </children>
</AnchorPane>