<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity"
            minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="731.0" prefWidth="942.0"
            xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.smarthotel.gui.TelaBuscarHospedagemController">

   <children>
      <Label layoutX="374.0" layoutY="49.0" text="SMART HOTEL">
         <font>
            <Font name="System Bold" size="28.0" />
         </font>
      </Label>

      <Label layoutX="403.0" layoutY="109.0" text="Buscar Hospedagem">
         <font>
            <Font name="System Bold" size="14.0" />
         </font>
      </Label>

      <Label layoutX="66.0" layoutY="180.0" text="ID da Hospedagem:">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Label>

      <TextField fx:id="txtIdHospedagem"
                 layoutX="66.0" layoutY="198.0" />

      <Button fx:id="btnBuscar"
              layoutX="226.0" layoutY="198.0"
              mnemonicParsing="false"
              onAction="#buscarHospedagem"
              text="Buscar">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Button>

      <Label layoutX="66.0" layoutY="258.0" text="Responsável:">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Label>

      <Label fx:id="lblResponsavel"
             layoutX="160.0" layoutY="258.0"
             text="-">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Label>

      <Label layoutX="66.0" layoutY="310.0" text="Hóspedes:">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Label>

      <ListView fx:id="listHospedes"
                layoutX="65.0" layoutY="328.0"
                prefHeight="96.0" prefWidth="155.0" />

      <Label layoutX="67.0" layoutY="436.0" text="Quarto:">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Label>

      <Label fx:id="lblQuarto"
             layoutX="130.0" layoutY="436.0"
             text="-">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Label>

      <Label layoutX="63.0" layoutY="474.0" text="Status:">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Label>

      <Label fx:id="lblStatus"
             layoutX="130.0" layoutY="474.0"
             text="-">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Label>

      <Label layoutX="66.0" layoutY="525.0" text="Entrada:">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Label>

      <Label fx:id="lblEntrada"
             layoutX="140.0" layoutY="525.0"
             text="-">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Label>

      <Label layoutX="65.0" layoutY="583.0" text="Saída:">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Label>

      <Label fx:id="lblSaida"
             layoutX="130.0" layoutY="583.0"
             text="-">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Label>

      <Button fx:id="btnGerenciarHospedagem"
              layoutX="759.0" layoutY="601.0"
              mnemonicParsing="false"
              onAction="#abrirGerenciarHospedagem"
              text="Gerenciar Hospedagem">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Button>

      <Button fx:id="btnVoltar"
              layoutX="445.0" layoutY="679.0"
              mnemonicParsing="false"
              onAction="#voltar"
              text="Voltar">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Button>
   </children>
</AnchorPane>